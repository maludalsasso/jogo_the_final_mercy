      escreva("▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓░░░▓▓▓▓▓▓▓▓▓░░░▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓\n")
      escreva("▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▒░░░░▓▓▓▓▓▓▓▓▓░▒▒▒░▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓\n\n")

      u.aguarde(2500)
     
    
		digitar("Você acorda em Desterro, 1823.\n", 30)
		digitar("O ar é úmido e pesado.\n", 30)
		digitar("O cheiro de maresia invade o quarto.\n", 30)
		digitar("A lamparina pisca lentamente, como se fosse apagar a qualquer momento.\n", 30)
		animarPontos(3, 280)
		digitar("A janela bate com força.\n", 30)

		animarTocToc()

		digitar("O vento entra gelado.\n", 30)
		digitar("Você sente como se não estivesse sozinho.\n\n", 30)

		animarPassos()

		digitar("A porta se abre lentamente.\n", 30)
		digitar("Uma mulher entra.\n", 30)
		digitar("Vestida de preto. Olhar cansado... mas atento demais.\n\n", 30)

		digitar(" ???: Finalmente você acordou...\n", 28)
		digitar(" Eu sou a senhora Alzira.\n", 28)
		digitar(" Encontrei você jogado na rua, quase morto.\n", 28)
		digitar(" Cuidei de você.\n\n", 28)

		enquanto (perguntouOnde == 0 ou perguntouQuem == 0) // O jogo continua perguntando até o jogador fazer as duas perguntas
		{
			escreva("1 - Onde estou?\n")
			escreva("2 - Quem é você?\n")
			escreva("Escolha: ")
			leia(opcao)
			escreva("\n")

