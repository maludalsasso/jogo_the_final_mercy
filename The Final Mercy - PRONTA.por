		leia(opcao) // lê a escolha do jogador
		escreva("\n")

		escolha (opcao) // estrutura de decisão baseada na escolha do jogador
		{
			caso 1:
				finalDerrotaFuga() // chama o final de derrota por fuga
				pare

			caso 2:
				se (suspeita >= 2) // verifica se o jogador acumulou suspeita suficiente
				{
					finalVitoria() // libera final correto - (vitória)
				}
				senao
				{
					finalDerrotaFuga() // sem suspeita suficiente, falha
				}
				pare

			caso 3:
				finalAlternativo() // chama o final alternativo
				pare

			caso contrario:
				finalDerrotaFuga()   // chama o final derrota por fuga
		}
	}

	funcao finalDerrotaInicio() 
	{

		limpaTela() // limpa a tela antes de exibir o final

		digitar("O olhar de Alzira muda.\n", 30)
		digitar("Frio. Vazio.\n\n", 30)
		digitar("Alzira: Então... saia da minha casa.\n", 28)
		animarPontos(3, 250) // pausa com animação de pontos
		digitar("Você tenta se levantar.\n", 30)
		digitar("Mas algo aperta sua garganta.\n", 30)
		digitar("Você não consegue respirar.\n", 30)
		digitar("A última coisa que vê é o sorriso de Alzira.\n\n", 30)
	}

