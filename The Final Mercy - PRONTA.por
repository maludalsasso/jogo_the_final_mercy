programa
{
	inclua biblioteca Util --> u //  usada para pausas/animações com aguarde()
	inclua biblioteca Texto --> t // usada para contar caracteres e extrair letras no efeito de digitação

	inteiro suspeita = 0 // guarda quantas pistas estranhas o jogador encontrou
	inteiro confiancaAlzira = 0 // registra quando o jogador acredita em Alzira
	inteiro opcao = 0 // variável geral para armazenar as escolhas do jogador

	funcao inicio()
	{
		introducao()
		capitulo1()
	}

	funcao limpaTela()
	{
		inteiro i
		para (i = 0; i < 8; i = i + 1)
		{
			escreva("\n")
		}
	}

	funcao pausar(inteiro tempo)
	{
		u.aguarde(tempo)
	}

	funcao digitar(cadeia texto, inteiro velocidade) // Mostra o texto letra por letra para criar clima de narrativa
	{
		inteiro i
		cadeia letra

		para (i = 0; i < t.numero_caracteres(texto); i = i + 1)
		{
			letra = t.extrair_subtexto(texto, i, i + 1) // essa linha faz o efeito de “digitação”, pegando uma letra por vez do texto
			escreva(letra)
			u.aguarde(velocidade)
		}
	}

	funcao animarPontos(inteiro quantidade, inteiro tempo) // Usada em momentos de suspense para mostrar pausas dramáticas
	{
		inteiro i
		para (i = 0; i < quantidade; i = i + 1)
		{
			escreva(".")
			u.aguarde(tempo)
		}
		escreva("\n")
	}

	funcao animarTocToc()
	{
		escreva("\n")
		digitar("TOC", 300)
		u.aguarde(250)
		escreva("... ")
		digitar("TOC", 300)
		u.aguarde(250)
		escreva("... ")
		digitar("TOC", 300)
		escreva("...\n\n")
		u.aguarde(400)
	}

	funcao animarPassos()
	{
		digitar("Passos se aproximam", 40)
		animarPontos(3, 250)
		digitar("toc", 300)
		u.aguarde(180)
		escreva(" ")
		digitar("toc", 300)
		u.aguarde(180)
		escreva(" ")
		digitar("toc", 300)
		escreva("\n\n")
	}

	funcao introducao()
	{
		cadeia continuar

		limpaTela()
///------------------------------------------- INTRODUÇÃO/ TELA INICIAL----------------------------------------------------------
		escreva("████████╗██╗░░██╗███████╗  ███████╗██╗███╗░░██╗░█████╗░██╗░░░░░  ███╗░░░███╗███████╗██████╗░░█████╗░██╗░░░██╗\n")
		escreva("╚══██╔══╝██║░░██║██╔════╝  ██╔════╝██║████╗░██║██╔══██╗██║░░░░░  ████╗░████║██╔════╝██╔══██╗██╔══██╗╚██╗░██╔╝\n")
		escreva("░░░██║░░░███████║█████╗░░  █████╗░░██║██╔██╗██║███████║██║░░░░░  ██╔████╔██║█████╗░░██████╔╝██║░░╚═╝░╚████╔╝░\n")
		escreva("░░░██║░░░██╔══██║██╔══╝░░  ██╔══╝░░██║██║╚████║██╔══██║██║░░░░░  ██║╚██╔╝██║██╔══╝░░██╔══██╗██║░░██╗░░╚██╔╝░░\n")
		escreva("░░░██║░░░██║░░██║███████╗  ██║░░░░░██║██║░╚███║██║░░██║███████╗  ██║░╚═╝░██║███████╗██║░░██║╚█████╔╝░░░██║░░░\n")
		escreva("░░░╚═╝░░░╚═╝░░╚═╝╚══════╝  ╚═╝░░░░░╚═╝╚═╝░░╚══╝╚═╝░░╚═╝╚══════╝  ╚═╝░░░░░╚═╝╚══════╝╚═╝░░╚═╝░╚════╝░░░░╚═╝░░░\n")

		digitar("                                                     Desterro, 1823.\n", 35)
		digitar("                                 O mar guarda segredos que a terra não consegue esconder.\n", 35)
		digitar("                                          Algumas casas envelhecem com o tempo.\n", 35)
		digitar("                                             Outras apodrecem por dentro.\n", 35)
		                                                              animarPontos(3, 250)
		digitar("                                 E há lugares onde a morte não sabe permanecer em silêncio.\n\n", 35)

		digitar("                                   Pressione ENTER ou escreva qualquer coisa para continuar: ", 20)
		leia(continuar)
	}

