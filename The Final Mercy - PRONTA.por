	digitar("A respiração falha.\n", 30)
	digitar("O coração dispara.\n\n", 30)

	digitar("Então você ergue os olhos.\n", 30)
	animarPontos(3, 250)  // pausa visual antes de revelar a cena

	digitar("A casa está diante de você outra vez.\n", 30)
	digitar("A mesma janela.\n", 30)
	digitar("A mesma porta entreaberta.\n", 30)
	digitar("O mesmo silêncio.\n\n", 30)

	digitar("Você tenta recuar.\n", 30)
	digitar("Mas alguma coisa prende seus pés.\n", 30)
	digitar("Como se a casa ainda estivesse esperando por você.\n\n", 30)

	digitar("Lá dentro, uma lamparina se acende sozinha.\n", 30)
	animarPontos(3, 250) // cria intervalo antes da fala final
	digitar("E uma voz sussurra ao longe:\n", 30)
	digitar("Você nunca saiu.\n\n", 35)
}

funcao finalVitoria()
{
	limpaTela() // limpa a tela do console

	digitar("Você avança antes que Alzira possa reagir.\n", 30)
	digitar("Com toda a força, empurra o cálice de suas mãos.\n", 30)
	digitar("Ele cai contra a pedra.\n", 30)
	digitar("E se parte em dois.\n\n", 30)   // destruição do objeto principal
