funcao mostrarCartaECartao()
{
	  escreva(" ╔══════════════════════════════════════════════════════════╗\n")
		escreva(" ║                                                          ║\n")
		escreva(" ║   Se você encontrou isto, então já é tarde demais        ║\n")
		escreva(" ║   para mim.                                              ║\n")
		escreva(" ║                                                          ║\n")
		escreva(" ║   Nem tudo que foi enterrado permanece em silêncio.      ║\n")
		escreva(" ║   Há algo escondido onde a pedra encontra o mar.         ║\n")
		escreva(" ║                                                          ║\n")
		escreva(" ║   Não confie...                                          ║\n")
		escreva(" ║   [...]                                                  ║\n")
		escreva(" ║                                                          ║\n")
		escreva(" ║   O cálice não devolve. Ele cobra.                       ║\n")
		escreva(" ║   Se ainda houver tempo, não siga adiante.               ║\n")
		escreva(" ║                                                          ║\n")
		escreva(" ║                                       Eulélia            ║\n")
		escreva(" ║                                                          ║\n")
		escreva(" ╚══════════════════════════════════════════════════════════╝\n\n")

	 
	digitar("O cartão mostra uma paisagem.\n", 30)
	digitar("Grandes pedras à beira do mar.\n", 30)
	digitar("Ondas fortes quebrando contra elas.\n", 30)
	digitar("No verso, está escrito à mão:\n", 30)
	digitar("—Onde a água insiste...\n", 28)
	digitar("e a fé se esconde na pedra...\n", 28)
	digitar("é lá que tudo começa.\n\n", 28)

	digitar("As mãos de Alzira tremem levemente.\n", 28)
	digitar("Alzira: Esse lugar...\n", 28)
	animarPontos(3, 220) // pausa com animação para transição da fala
	digitar(" Eu conheço. Fica em Itaguaçu.\n", 28)
	digitar(" Eu posso trazê-la de volta.\n", 28)
	digitar(" Você acredita nisso, não acredita?\n\n", 28)

	escreva("1 - Sim, devemos tentar\n")
	escreva("2 - Isso parece perigoso\n")
	escreva("Escolha: ")
	leia(opcao) // lê a escolha do jogador

	escreva("\n")

	se (opcao == 1)  // jogador decide confiar em Alzira
	{

	confiancaAlzira = confiancaAlzira + 1
	digitar("Alzira sorri.\n\n", 28)
	digitar("Alzira: Eu sabia...\n", 28)
	animarPontos(2, 200) // pequena pausa visual
	digitar("Talvez ainda haja esperança.\n\n", 28)

	digitar("Ela guarda o envelope com cuidado.\n", 28)
	digitar("O silêncio volta a tomar a sala.\n", 28)
	digitar("-Ainda há outros lugares para procurar.\n\n", 28)

	}
	senao  // jogador desconfia de Alzira
	{
		suspeita = suspeita + 1 // aumenta o nível de suspeita
		digitar("Ela te encara por tempo demais.\n\n", 28)
		digitar("Alzira: Perigoso...?\n", 28)
		animarPontos(3, 200) // pausa antes da resposta
		digitar("Alzira: Ou necessário?\n\n", 28)
    u.aguarde(2500)
    limpa()
	}
}
//----------------------------------------------- CAPÍTULO 3--------------------------------------------
funcao capitulo3()
{
	limpaTela() // limpa a tela antes de iniciar o capítulo
      escreva("═════════════════════════════\n")
      escreva("┏━╸┏━┓┏━┓╻╺┳╸╻ ╻╻  ┏━┓   ┏━┓\n")
      escreva("┃  ┣━┫┣━┛┃ ┃ ┃ ┃┃  ┃ ┃   ╺━┫\n")
      escreva("┗━╸╹ ╹╹  ╹ ╹ ┗━┛┗━╸┗━┛   ┗━┛\n")
      escreva("═════════════════════════════\n\n")
      u.aguarde(1000)
	digitar("Você observa as plantas.\n", 30)
	digitar("A terra está revirada.\n", 30)
	digitar("Entre as raízes e a terra úmida, há um baú semi-enterrado.\n", 30)
	digitar("A fechadura está enferrujada.\n", 30)
	digitar("Por um instante, você se lembra da chave encontrada no armário.\n", 30)

	escreva("1 - Tentar abrir o baú com a chave\n")
	escreva("2 - Ignorar\n")
	escreva("Escolha: ")
	leia(opcao) // lê a escolha do jogador
	escreva("\n")

	se (opcao == 1)
	{
			suspeita = suspeita + 1
      limpa()
			escreva("%%%%%%@@@@@@%%%%%%@@@@@@%%%%%%@@@@@@%%%%%%@@@@@@%%%%%%@@@@@@%%%%%%@@@@@@%%%%%%@@@@@@%%%%%%@@@@@@%%%%%%@@@@@@%%%%%%@@@@@@%%%%%%@@\n")
      escreva("@@@@@@%%%%%%@@@@@@%%%%%%@@@@@@%%%%%%@@@@@@%%%%%%@@@@@@%%%%%%@@@@@@%%%%%%@@@@@@%%%%%%@@@@@@%%%%%%@@@@@@%%%%%%@@@@@@%%%%%%@@@@@@%%\n")
