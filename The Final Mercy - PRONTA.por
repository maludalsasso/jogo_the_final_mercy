//-------------------------------------- CAPÍTULO 2-----------------------------------------------

  funcao capitulo2()
{
  limpa()
	logico olhouEscrivaninha = falso // No começo, todas estão em falso, porque o jogador ainda não procurou em nenhum lugar
	logico olhouSofa = falso
	logico olhouArmario = falso
