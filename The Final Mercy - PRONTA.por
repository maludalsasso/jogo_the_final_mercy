      limpaTela()
      
	digitar("A escada range a cada passo.\n", 30)
	digitar("A casa parece viva.\n", 30)
	digitar("Observando.\n", 30)
	digitar("Vocês chegam até a sala.\n", 30)
	digitar("Uma mesa está posta.\n", 30)
	digitar("Comida fresca.\n", 30)
	digitar("Mas ninguém cozinhou.\n", 30)
	animarPontos(3, 240) // pausa com animação para transição da cena

	digitar("Alzira: Antes de comer...\n", 28)
	digitar("Você poderia me ajudar a encontrar algo?\n", 28)
	digitar("Minha irmã deixou uma carta antes de morrer, e não sei onde os criados a guardaram.\n\n", 28)

	enquanto (olhouEscrivaninha == falso ou olhouSofa == falso ou olhouArmario == falso) // repete enquanto a condição for verdadeira
	{
		escreva("Onde mais você deseja procurar?\n")

		se (olhouEscrivaninha == falso) // o laço continua até os 3 lugares terem sido visitados
		{
			escreva("1 - Escrivaninha\n")
		}

		se (olhouSofa == falso) // só mostra opção se ainda não foi visitada
		{
			escreva("2 - Embaixo do sofá\n")
		}

		se (olhouArmario == falso) // só mostra opção se ainda não foi visitada
		{
			escreva("3 - Armário\n")
		}

		escreva("Escolha: ")
		leia(opcao)
		escreva("\n")

		escolha (opcao) // escolha funciona como um menu de casos
		{
			caso 1:
				se (olhouEscrivaninha == falso) // verifica se o local ainda não foi investigado
				{ 
					olhouEscrivaninha = verdadeiro // marca a escrivaninha como já visitada

					escreva("@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@\n")
