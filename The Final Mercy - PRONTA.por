		digitar("Você se ajoelha diante do baú.\n", 30)
		digitar("Com a mão tremendo, encaixa a chave na fechadura.\n", 30)
		animarPontos(3, 250)  // executa pausa com animação de pontos
		digitar("Por um instante, parece que vai funcionar.\n", 30)
		digitar("Então, um estalo seco corta o silêncio.\n", 30)
		digitar("A chave quebra dentro da fechadura.\n\n", 30)

		digitar("Um cheiro estranho sobe da madeira.\n", 30)
		digitar("Você recua imediatamente.\n\n", 30)
		
		digitar("Alzira observa em silêncio.\n", 28)
		digitar("Por um momento, o rosto dela parece perder a cor.\n\n", 28)
	}
	senao
	{
		digitar("Você decide não tocar no baú.\n", 30)
		digitar("Mas a sensação de que algo está errado continua ali.\n\n", 30)
	}

	digitar("Alzira: Precisamos ir até Itaguaçu.\n", 28)
	digitar("O cálice está lá.\n", 28)
	digitar("Alzira segura sua mão, fria demais.\n\n", 28)
	digitar("Alzira: Você vem comigo... não vem?\n\n", 28)
  u.aguarde(6000)
  limpa()
	caminhoItaguacu() // chama a função responsável pelo próximo capítulo do jogo

} 
 
funcao caminhoPraia() 
{ 
    digitar("Você segue pela praia.\n", 30) 
    digitar("O vento é forte.\n", 30) 
    digitar("O mar está agitado.\n", 30) 
    digitar("...\n", 30) 
    digitar("O caminho desaparece na água.\n", 30) 
    digitar("Não há passagem por aqui.\n\n", 40) 

    suspeita = suspeita + 1 // incrementa o nível de suspeita do jogador
} 

funcao caminhoPedras() 
{  
    limpaTela()
    digitar("Você segue pelas pedras.\n", 30) 
    digitar("O caminho é difícil.\n", 30) 
    digitar("...\n", 30) 
    digitar("Você vê marcas estranhas nas rochas.\n\n", 40) 
    digitar("E decide seguir por lá mesmo...\n", 40) 
    digitar("E, no final do caminho, encontra uma gruta.\n", 40) 
    u.aguarde(3000)

    suspeita = suspeita + 1 // incrementa o nível de suspeita do jogador
} 
//------------------------------------------------------------- CAPÍTULO 4-------------------------------------------
funcao caminhoItaguacu()
{
    inteiro opcao
    cadeia pausa
    logico caminhoCorreto = falso // controla se o jogador já escolheu um caminho válido

    enquanto (caminhoCorreto == falso) // repete até uma escolha válida ser feita
    {
        limpaTela() // limpa a tela a cada tentativa

        escreva("═════════════════════════════\n")
        escreva("┏━╸┏━┓┏━┓╻╺┳╸╻ ╻╻  ┏━┓   ╻ ╻\n")
        escreva("┃  ┣━┫┣━┛┃ ┃ ┃ ┃┃  ┃ ┃   ┗━┫\n")
        escreva("┗━╸╹ ╹╹  ╹ ╹ ┗━┛┗━╸┗━┛     ╹\n")
        escreva("═════════════════════════════\n\n")
        u.aguarde(1000)
        
        digitar("Vocês caminham em silêncio.\n", 30)
        digitar("O som do mar fica mais forte.\n", 30)
        digitar("A neblina cobre o caminho.\n", 30)
        digitar("...\n", 30)
        digitar("Alzira para.\n", 30)
        digitar("-Existem dois caminhos.\n", 28)
        digitar("Pela praia... ou pelas pedras.\n", 28)

        escreva("Para onde você vai?\n")
        escreva("1 - Praia\n")
        escreva("2 - Pedras\n")
        escreva("Escolha: ")
        leia(opcao) // lê a opção escolhida pelo jogador
        escreva("\n")

        se (opcao == 1)
        {
            caminhoPraia() // executa o caminho da praia
            digitar("\nAlgo não parece certo...\n", 30)
            digitar("O caminho termina em um trecho perigoso.\n", 30)
            digitar("Você decide voltar.\n", 30)
            digitar("Sem outra escolha, vocês seguem pelas pedras.\n", 30)
            u.aguarde(2300)

            caminhoPedras() // força o jogador a seguir pelas pedras
            caminhoCorreto = verdadeiro // encerra o loop
        }
        senao se (opcao == 2)
        {
            caminhoPedras()  // executa diretamente o caminho correto
            caminhoCorreto = verdadeiro // encerra o loop
        }
        senao
        {
            escreva("Opção inválida!\n")
            escreva("Pressione ENTER para tentar novamente...")
            leia(pausa) // pausa até o usuário pressionar ENTER
        }
    }

    u.aguarde(2300)
    capituloFinal() // chama o capítulo final após escolha válida
}

