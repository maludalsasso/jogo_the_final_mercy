	animarPontos(3, 220)
	digitar("E desaparece como neblina ao amanhecer.\n\n", 30)

	digitar("Lá fora, o jardim finalmente floresce.\n", 30)
	digitar("As flores voltam a nascer sobre a terra antes morta.\n\n", 30)

	
	digitar("Nem toda morte queria vingança.\n", 28)
	digitar("Algumas apenas esperavam para ser libertas.\n", 28)
}

funcao finalAlternativo()
{
	limpaTela()

	digitar("Você entrega o cálice a Alzira.\n", 30)
	digitar("As mãos dela tremem de ansiedade.\n", 30)
	digitar("Seus olhos brilham como se a vitória estivesse próxima.\n\n", 30)

	digitar("Alzira: Finalmente...\n", 28)
	digitar("Ela leva o cálice aos lábios.\n", 30)
	digitar("E bebe.\n\n", 30)
	animarPontos(3, 250)
