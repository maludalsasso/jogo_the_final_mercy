						digitar("Você já fez essa pergunta.\n\n", 25)
					}
					pare

				caso 2:
					se (perguntouQuem == 0) // ainda não perguntou
					{
						digitar("Alzira: Sou apenas uma mulher que perdeu tudo.\n\n", 28)
						digitar("Ela força um leve sorriso.\n\n", 28)
						digitar("Alzira: Minha irmã morreu há pouco tempo.\n", 28)
						digitar("E, desde então... nada mais é como antes.\n\n", 28)
						perguntouQuem = 1 // já perguntou
					}
					senao
					{
						digitar("Você já fez essa pergunta.\n\n", 25)
					}
					pare

				caso contrario: // depois de perguntar as 2
					digitar("Opção inválida.\n\n", 25)
			}
		}

		digitar("Alzira baixa o olhar por um instante.\n", 28)
		digitar("Quando volta a encarar você, sua voz parece mais firme.\n\n", 28)

		digitar("Alzira: Agora que você já sabe quem sou...\n", 28)
		digitar("preciso lhe pedir um favor.\n", 28)
